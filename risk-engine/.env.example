# Redis
REDIS_URL=redis://localhost:6379

# Exchanges & symbols to monitor (must match market-data config)
RISK_EXCHANGES=binance,bybit
RISK_SYMBOLS=BTC/USDT:USDT,ETH/USDT:USDT

# Account polling interval (ms)
POLL_INTERVAL_MS=5000

# Drawdown thresholds (%)
DD_WARNING_PCT=2
DD_DANGER_PCT=4
DD_CRITICAL_PCT=6
DD_MAX_PEAK_PCT=15
DD_PER_TRADE_PCT=3

# Exposure thresholds
EXP_HIGH_RATIO=3
EXP_IMBALANCE=0.8
EXP_CONCENTRATION=0.5
EXP_EXCHANGE_RISK=0.7

# Telegram alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# General
LOG_LEVEL=info
