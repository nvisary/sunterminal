# Redis
REDIS_URL=redis://localhost:6379

# Exchanges available for hedging (must match market-data config)
HEDGE_EXCHANGES=binance,bybit

# Global mode: advisor | controller
HEDGE_MODE=advisor

# Auto-Hedge
AUTO_HEDGE_ENABLED=true
AUTO_HEDGE_THRESHOLD=25
AUTO_HEDGE_UNHEDGE_THRESHOLD=10
AUTO_HEDGE_RATIO=0.5
AUTO_HEDGE_EXCHANGE=auto
AUTO_HEDGE_MAX_SIZE=100
AUTO_HEDGE_INTERVAL=5000
AUTO_HEDGE_MAX_COST_PCT=0.1

# Delta Neutral (P1)
DELTA_NEUTRAL_ENABLED=false

# Emergency Exit
EMERGENCY_AUTO_TRIGGER=true
EMERGENCY_DD_CRITICAL=true
EMERGENCY_DD_MAX_PEAK=true
EMERGENCY_RETRY_ATTEMPTS=3
EMERGENCY_RETRY_DELAY=3000

# General
LOG_LEVEL=info
