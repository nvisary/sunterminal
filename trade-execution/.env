# Redis
REDIS_URL=redis://localhost:6379

# Position Sizer
RISK_PER_TRADE=1
MAX_POSITION_USD=100
MAX_OPEN_POSITIONS=3
DEFAULT_LEVERAGE=5
ATR_MULTIPLIER=1.5
MARGIN_RESERVE=10

# Smart Order
DEFAULT_STRATEGY=limit
LIMIT_TIMEOUT=30000
MAX_SLIPPAGE=0.5

# Guards (block | warning | off)
GUARD_RISK_BLOCK=block
GUARD_HEDGE_LOCK=block
GUARD_BALANCE=block
GUARD_MAX_POSITIONS=block
GUARD_VOLATILITY=warning
GUARD_LEVEL_PROXIMITY=warning
GUARD_FUNDING_COST=warning

# General
LOG_LEVEL=info
